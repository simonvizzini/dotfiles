# Reference template for ~/.config/chezmoi/chezmoi.toml on a new machine.
# Copy this to ~/.config/chezmoi/chezmoi.toml BEFORE running `chezmoi init --apply`.
# This file is NOT applied to the destination — see .chezmoiignore.

encryption = "age"

[age]
    identity = "~/.config/chezmoi/key.txt"
    # Public key is safe to commit; private key (key.txt) MUST NOT be in the repo.
    # Restore key.txt to ~/.config/chezmoi/key.txt from KeePassXC before running `chezmoi init --apply`.
    recipient = "age1nljqacs5k9sht2u78etusp96n79mmxyl2anemq4vkjctknlvap2qxthph4"

[data]
    # Set true on machines that should run the KeePassXC <-> rclone sync.
    # When true: cronie + rclone + keepassxc are installed, cronie.service is
    # enabled, the user crontab is written, and the encrypted rclone.conf is
    # decrypted into ~/.config/rclone/. Set false on VMs / throwaway machines
    # where you just want the shell + editor environment.
    keepass_sync = false

    # Only used when keepass_sync = true. Override per machine if your keepass
    # dir or rclone remote name differs.
    keepass_dir = "/home/simon/keepass"
    rclone_remote = "Hetzner:keepass"
