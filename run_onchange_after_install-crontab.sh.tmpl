#!/usr/bin/env bash
# Install the user crontab. Re-runs whenever the rendered content of this
# script changes. No-ops on machines where keepass_sync is false.

set -euo pipefail

{{ if not .keepass_sync -}}
echo "keepass_sync = false on this machine — skipping crontab install."
exit 0
{{- end }}

if ! command -v crontab >/dev/null 2>&1; then
    echo "crontab command not found — install cronie (or equivalent) first." >&2
    exit 0
fi

KEEPASS_DIR="{{ .keepass_dir }}"
RCLONE_REMOTE="{{ .rclone_remote }}"

crontab - <<EOF
#No comment
*/5 * * * *	/usr/bin/rclone bisync ${KEEPASS_DIR} ${RCLONE_REMOTE} --verbose --force
EOF

echo "user crontab installed:"
crontab -l
